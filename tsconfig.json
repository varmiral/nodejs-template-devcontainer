{
  "compilerOptions": {
    "target": "ES2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
    // "declaration": true,
    // "declarationMap": true,
    // "sourceMap": true,
    // "isolatedDeclarations": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
